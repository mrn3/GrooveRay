# MariaDB / MySQL (required)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=grooveray
MYSQL_PASSWORD=grooveray
MYSQL_DATABASE=grooveray

# Optional
PORT=3000
NODE_ENV=development
JWT_SECRET=your-secret-key-change-in-production
CORS_ORIGIN=http://localhost:5173

# Security: comma-separated IPs to block (alternative to backend/banned-ips.txt)
# BANNED_IPS=1.2.3.4,5.6.7.8

# YouTube: if you get "Sign in to confirm you're not a bot", set one of:
# YTDLP_COOKIES_FILE=/path/to/cookies.txt
# YTDLP_COOKIES_FROM_BROWSER=chrome

# Image search by name (playlists, stations, etc.). Get a key at https://unsplash.com/developers
# UNSPLASH_ACCESS_KEY=

# Sign in with Google (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# FRONTEND_URL=http://localhost:5173
# API_URL=http://localhost:3000
